# Copier vers .env avant le premier lancement :
#   cp .env.docker.example .env
#
# Développement local (pnpm dev) : DATABASE_URL avec localhost (voir .env.example)
# Docker Compose : remplacer localhost par supabase-db (ou db en prod)

# --- Base de données Supabase (PostgreSQL local) ---
POSTGRES_PASSWORD=postgres
POSTGRES_USER=postgres
POSTGRES_DB=postgres
# Port PostgreSQL exposé sur la machine hôte (évite conflit avec un Postgres déjà sur 5432)
POSTGRES_HOST_PORT=5433
DATABASE_URL=postgresql://postgres:postgres@db:5432/postgres

# --- Frontend Docker (port hôte → Nginx dans le conteneur) ---
APP_PORT=8090

# --- Backend ---
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
SERVE_STATIC=false
JWT_SECRET=change-me-in-production
OWNER_OPEN_ID=
OWNER_EMAIL=vincent.sanonc@gmail.com
ADMIN_SEED_PASSWORD=

# --- Auth OAuth / SSO (optionnel — build frontend + runtime backend) ---
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=
OAUTH_SERVER_URL=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Stockage S3 (Forge) ---
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# --- Google Gemini (rendus + compte rendu) ---
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_TEXT_MODEL=gemini-2.5-flash

# --- Analytics (optionnel) ---
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
