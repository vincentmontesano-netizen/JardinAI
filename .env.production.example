# Copier vers .env avant déploiement :
#   cp .env.production.example .env

# --- Domaine & TLS (Caddy) ---
DOMAIN=app.votredomaine.fr
ACME_EMAIL=admin@votredomaine.fr
HTTP_PORT=80
HTTPS_PORT=443

# --- Base de données (interne Docker, non exposée) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=remplacez-par-un-mot-de-passe-fort
POSTGRES_DB=jardinia
DATABASE_URL=postgresql://postgres:remplacez-par-un-mot-de-passe-fort@db:5432/jardinia

# --- Backend ---
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
SERVE_STATIC=false
TRUST_PROXY=true
JWT_SECRET=remplacez-par-une-chaine-aleatoire-longue
APP_ID=jardinia
OWNER_OPEN_ID=
# Compte admin (optionnel — créé/mis à jour au démarrage si défini)
OWNER_EMAIL=vincent.sanonc@gmail.com
ADMIN_SEED_PASSWORD=

# --- Auth OAuth / SSO (optionnel) ---
VITE_OAUTH_PORTAL_URL=
OAUTH_SERVER_URL=

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Optionnel en test (crédits via /payment/success sans webhook)
STRIPE_WEBHOOK_SECRET=

# --- Stockage S3 (Forge) ---
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# --- Google Gemini ---
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_TEXT_MODEL=gemini-2.5-flash

# --- Analytics (optionnel) ---
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
