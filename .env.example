# Base de données (PostgreSQL / Supabase)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Auth OAuth / SSO (optionnel — sinon email / mot de passe)
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=
OAUTH_SERVER_URL=
JWT_SECRET=change-me-in-production
OWNER_OPEN_ID=
OWNER_EMAIL=vincent.sanonc@gmail.com

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stockage S3 (Forge) — upload des photos et rendus
# En dev local, si ces variables sont vides, les fichiers vont dans .data/uploads/
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Google Gemini — rendus IA + compte rendu projet
# https://ai.google.dev/gemini-api/docs/image-generation
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_TEXT_MODEL=gemini-2.5-flash

# Serveur
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
SERVE_STATIC=true

# Analytics (optionnel)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# Emails transactionnels (Resend — reset mot de passe, messages admin)
# https://resend.com
RESEND_API_KEY=
EMAIL_FROM=Jardinia Studio <noreply@votredomaine.fr>

# Manus platform (désactivé par défaut en local — évite les warnings console)
# VITE_MANUS_RUNTIME=true
# VITE_MANUS_DEBUG=true
